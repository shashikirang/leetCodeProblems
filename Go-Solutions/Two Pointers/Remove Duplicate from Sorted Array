package main

import "fmt"

func removeDuplicates(nums []int) int {
	if len(nums) == 0 {
		return 0
	}

	k := 1 // position for next unique element

	for i := 1; i < len(nums); i++ {
		if nums[i] != nums[i-1] {
			nums[k] = nums[i]
			k++
		}
	}

	return k
}

func main() {
	nums := []int{0,0,1,1,1,2,2,3,3,4}
	k := removeDuplicates(nums)

	fmt.Println(k)        // Output: 5
	fmt.Println(nums[:k]) // Output: [0 1 2 3 4]
}
